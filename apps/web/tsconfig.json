{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "composite": true,
    "noEmit": true
  },
  "references": [
    { "path": "../../packages/shared" }
  ],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
